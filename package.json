{
  "name": "pos-system-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "postinstall": "pnpm --filter @pos/db generate",
    "type-check": "turbo run type-check",
    "db:push": "pnpm --filter @pos/db db:push",
    "db:studio": "pnpm --filter @pos/db db:studio",
    "db:generate": "pnpm --filter @pos/db generate",
    "db:seed": "pnpm --filter @pos/db seed",
    "setup": "pnpm install && pnpm db:generate && pnpm db:push"
  },
  "devDependencies": {
    "@prisma/nextjs-monorepo-workaround-plugin": "^7.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^9",
    "eslint-config-next": "^15.5.12",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "overrides": {
      "effect": ">=3.20.0",
      "defu": ">=6.1.5",
      "picomatch@<4": "2.3.2",
      "picomatch@>=4 <4.0.4": "4.0.4",
      "postcss": ">=8.5.10"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
