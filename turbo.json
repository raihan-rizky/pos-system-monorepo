{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "DIRECT_URL",
    "EASYOCR_API_KEY",
    "NEBIUS_API_KEY",
    "NEBIUS_MODEL",
    "R2_ACCOUNT_ID",
    "R2_ACCESS_KEY_ID",
    "R2_SECRET_ACCESS_KEY",
    "R2_BUCKET_NAME",
    "R2_ENDPOINT",
    "R2_PUBLIC_BASE_URL",
    "SUPABASE_SERVICE_KEY",
    "WEBHOOK_BASE_URL",
    "WAHA_BASE_URL",
    "WAHA_SESSION",
    "WAHA_API_KEY",
    "WAHA_WEBHOOK_SECRET",
    "CLOSING_DEAL_PUSH_SECRET",
    "VAPID_PRIVATE_KEY",
    "VAPID_SUBJECT",
    "NEXT_PUBLIC_VAPID_PUBLIC_KEY",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "EASYOCR_API_KEY",
        "NEBIUS_API_KEY",
        "NEBIUS_MODEL",
        "R2_ACCOUNT_ID",
        "R2_ACCESS_KEY_ID",
        "R2_SECRET_ACCESS_KEY",
        "R2_BUCKET_NAME",
        "R2_ENDPOINT",
        "R2_PUBLIC_BASE_URL",
        "SUPABASE_SERVICE_KEY",
        "WEBHOOK_BASE_URL",
        "WAHA_BASE_URL",
        "WAHA_SESSION",
        "WAHA_API_KEY",
        "WAHA_WEBHOOK_SECRET",
        "CLOSING_DEAL_PUSH_SECRET",
        "VAPID_PRIVATE_KEY",
        "VAPID_SUBJECT",
        "NEXT_PUBLIC_VAPID_PUBLIC_KEY",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "test": {}
  }
}
