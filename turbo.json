{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "SUPABASE_SERVICE_KEY",
        "WEBHOOK_BASE_URL",
        "WAHA_BASE_URL",
        "WAHA_SESSION",
        "WAHA_API_KEY",
        "WAHA_WEBHOOK_SECRET",
        "CLOSING_DEAL_PUSH_SECRET",
        "VAPID_PRIVATE_KEY",
        "VAPID_SUBJECT",
        "NEXT_PUBLIC_VAPID_PUBLIC_KEY",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "test": {}
  }
}
