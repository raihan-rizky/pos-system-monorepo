# WhatsApp Cloud API
# Get these from: Meta Developer Portal > Your App > WhatsApp > API Setup
# Token: Temporary or permanent access token for WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_cloud_api_token
# Phone Number ID: The ID of your WhatsApp Business phone number (not the phone number itself)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
# Verify Token: Custom string you set in Meta webhook config for endpoint verification
WHATSAPP_VERIFY_TOKEN=your_verify_token

