# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Prisma - Supabase connection strings
# Replace [YOUR-PASSWORD] with your Supabase database password
DATABASE_URL=postgresql://postgres.[ref]:password@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[ref]:password@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres

# WAHA (WhatsApp HTTP API) - Self-hosted WhatsApp API
# Base URL of your WAHA server instance
WAHA_BASE_URL=http://localhost:3000
# Session name (default: "default")
WAHA_SESSION=default
# API key for authentication (from WAHA dashboard)
WAHA_API_KEY=your_waha_api_key_here
# Shared secret required by /api/wa/webhook. Send it as
# Authorization: Bearer <secret> or X-Webhook-Secret: <secret>.
WAHA_WEBHOOK_SECRET=your_webhook_secret_here
# Webhook base URL (your public app URL)
WEBHOOK_BASE_URL=https://your-app-url.vercel.app

# Browser Web Push (PWA notifications)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_public_vapid_key_here
VAPID_PRIVATE_KEY=your_private_vapid_key_here
VAPID_SUBJECT=mailto:admin@example.com

# Product image import OCR / Vision fallback
# EasyOCR is optional. If it is missing or unauthorized, the API falls back to Nebius Vision.
EASYOCR_API_KEY=your_easyocr_api_key_here
# Required for image import Vision fallback.
NEBIUS_API_KEY=your_nebius_api_key_here
# Chat model used by the POS assistant.
NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct
# Comma-separated deterministic assistant intents. Empty keeps every request on
# the model fallback. Enable one intent at a time after validating its corpus.
# Example: social_static,get_low_stock_items,get_daily_sales_summary
AI_FAST_PATH_INTENTS=

# Cloudflare R2 - proof images only (server-side credentials)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=pos-media
R2_ENDPOINT=https://your-cloudflare-account-id.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://your-public-bucket-id.r2.dev
