{
  "name": "@pos/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3002",
    "build": "pnpm --filter @pos/db generate && next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "db:migrate:prod": "pnpm --filter @pos/db db:migrate:prod",
    "assistant:evaluate": "vitest run features/ai-assistant/evaluation/__tests__/assistant-workflow-evaluation.test.ts",
    "assistant:concurrency": "vitest run features/ai-assistant/evaluation/__tests__/assistant-concurrency-harness.test.ts",
    "assistant:cost": "vitest run features/ai-assistant/evaluation/__tests__/assistant-cost-baseline.test.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@pos/db": "workspace:*",
    "@pos/ui": "workspace:*",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "@tanstack/react-query": "^5.60.0",
    "clsx": "^2.1.1",
    "dexie": "^4.4.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.14.0",
    "motion": "^12.40.0",
    "next": "^15.5.18",
    "openai": "^6.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-error-boundary": "^6.1.2",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.6.0",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@pos/config": "workspace:*",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vitest": "^4.1.6"
  }
}