{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "baseUrl": "../..",
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": ["apps/web/*"],
      "@pos/db": ["packages/db/src/index.ts"]
    },
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "../../packages/db/src/**/*.ts"
  ]
}
