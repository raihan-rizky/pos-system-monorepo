{
  "name": "@pos/db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:push": "prisma db push",
    "db:push:dev": "dotenv -e .env.development -- prisma db push",
    "db:push:prod": "dotenv -e .env.production -- prisma db push",
    "db:migrate:dev": "dotenv -e .env.development -- prisma migrate dev",
    "db:migrate:prod": "dotenv -e .env.production -- prisma migrate deploy",
    "db:migrate-reset:dev": "dotenv -e .env.development -- prisma migrate reset",
    "db:migrate-reset:prod": "dotenv -e .env.production -- prisma migrate reset",
    "db:pull": "prisma db pull",
    "db:studio": "prisma studio",
    "build": "prisma generate && node -e \"const fs=require('fs');fs.mkdirSync('dist',{recursive:true});fs.writeFileSync('dist/.build','prisma generated\\n')\"",
    "generate": "prisma generate",
    "postinstall": "prisma generate",
    "migrate:base-units": "tsx scripts/migrate-base-units.ts",
    "seed": "tsx src/seed.ts",
    "seed:dev": "dotenv -e .env.development -- tsx src/seed.ts",
    "seed:prod": "dotenv -e .env.production -- tsx src/seed.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
