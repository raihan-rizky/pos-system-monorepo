/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tender_offers {
  id               String        @id @db.Uuid
  user_id          String        @db.Uuid
  product_id       String        @db.Uuid
  company_id       String        @db.Uuid
  offer_date       DateTime      @db.Date
  tender_reference String?
  offered_price    Decimal?      @db.Decimal(14, 2)
  quantity         Decimal?      @db.Decimal(14, 2)
  currency         String        @default("THB")
  status           tender_status @default(draft)
  notes            String?
  created_at       DateTime      @default(now()) @db.Timestamptz(6)
  updated_at       DateTime      @db.Timestamptz(6)
  companies        companies     @relation(fields: [company_id], references: [id])
  products         products      @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([product_id, offer_date(sort: Desc)])
  @@index([user_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model waha_events {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_name String
  chat_id    String?
  message_id String?
  payload    Json
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([chat_id, created_at(sort: Desc)], map: "idx_waha_events_chat_id_created_at")
}

