generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                                  String                        @id @default(cuid())
  username                            String                        @unique
  name                                String
  role                                Role                          @default(CASHIER)
  password                            String?
  avatarUrl                           String?
  isActive                            Boolean                       @default(true)
  storeId                             String?
  createdAt                           DateTime                      @default(now())
  updatedAt                           DateTime                      @updatedAt
  batchOperations                     BatchOperation[]              @relation("created_batch_operations")
  undoneBatchOperations               BatchOperation[]              @relation("undone_batch_operations")
  shifts                              CashierShift[]
  createdCategoryCustomerPricingRules CategoryCustomerPricingRule[] @relation("created_category_customer_pricing_rules")
  updatedCategoryCustomerPricingRules CategoryCustomerPricingRule[] @relation("updated_category_customer_pricing_rules")
  recordedExpenses                    Expense[]                     @relation("recorded_expenses")
  productImportJobs                   ProductImportJob[]            @relation("created_product_import_jobs")
  productionActivityLogs              ProductionActivityLog[]       @relation("production_activity_actor")
  inventoryTasksSubmitted             InventoryTask[]               @relation("inventory_task_submitter")
  inventoryDaySessionsCheckedIn       InventoryDaySession[]         @relation("inventory_day_session_checkin")
  inventoryDaySessionsCheckedOut      InventoryDaySession[]         @relation("inventory_day_session_checkout")
  inventoryTaskChecklistCreated       InventoryTaskChecklistItem[]  @relation("inventory_task_checklist_creator")
  inventoryTaskChecklistUpdated       InventoryTaskChecklistItem[]  @relation("inventory_task_checklist_updater")
  inventoryTaskChecklistCompleted     InventoryTaskChecklistItem[]  @relation("inventory_task_checklist_completer")
  inboundReceiptsSubmitted            InventoryInboundReceipt[]      @relation("inventory_inbound_submitter")
  inboundReceiptsApproved             InventoryInboundReceipt[]      @relation("inventory_inbound_approver")
  inventoryLogVerifications           InventoryLogVerification[]     @relation("inventory_log_verifier")
  inventoryLogCorrectionsRequested    InventoryLogCorrectionRequest[] @relation("inventory_log_correction_requester")
  inventoryLogCorrectionsDecided      InventoryLogCorrectionRequest[] @relation("inventory_log_correction_decider")
  internalStockOutRequestsCreated     InternalStockOutRequest[]      @relation("internal_stock_out_requester")
  internalStockOutRequestsApproved    InternalStockOutRequest[]      @relation("internal_stock_out_approver")
  internalStockOutRequestsRejected    InternalStockOutRequest[]      @relation("internal_stock_out_rejector")
  transactions                        Transaction[]                 @relation("processed_transactions")
  requestedTransactions               Transaction[]                 @relation("requested_transactions")
  store                               Store?                        @relation(fields: [storeId], references: [id])

  @@map("pos_users")
}

model Store {
  id                           String                        @id @default(cuid())
  name                         String
  address                      String?
  phone                        String?
  logoUrl                      String?
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  batchOperations              BatchOperation[]
  shifts                       CashierShift[]
  customerCategoryPricingRules CategoryCustomerPricingRule[]
  customers                    Customer[]
  debtPaymentLogs              DebtPaymentLog[]
  printingServices             PrintingService[]
  priceLogs                    ProductPriceLog[]
  productImportJobs            ProductImportJob[]
  inventoryTasks               InventoryTask[]
  inventoryDaySessions          InventoryDaySession[]
  inventoryProductionMaterials  InventoryProductionMaterial[]
  inventoryTaskChecklistItems   InventoryTaskChecklistItem[]
  inventoryInboundReceipts     InventoryInboundReceipt[]
  inventoryLogVerifications    InventoryLogVerification[]
  inventoryLogCorrections      InventoryLogCorrectionRequest[]
  internalStockOutRequests     InternalStockOutRequest[]
  productStockGroups           ProductStockGroup[]
  productionActivityLogs       ProductionActivityLog[]
  products                     Product[]
  salespersons                 Salesperson[]
  shoppingRequests             ShoppingRequest[]
  suratJalan                   SuratJalan[]
  transactions                 Transaction[]
  users                        User[]

  @@map("pos_stores")
}

model Category {
  id                           String                        @id @default(cuid())
  name                         String                        @unique
  icon                         String?
  color                        String?
  order                        Int                           @default(0)
  customerCategoryPricingRules CategoryCustomerPricingRule[]
  products                     Product[]

  @@map("pos_categories")
}

model Product {
  id                      String                      @id @default(cuid())
  name                    String
  sku                     String                      @unique
  barcode                 String?
  description             String?
  price                   Decimal                     @db.Decimal(12, 2)
  costPrice               Decimal?                    @db.Decimal(12, 2)
  stock                   Float                       @default(0)
  minStock                Int                         @default(5)
  unit                    String                      @default("pcs")
  categoryId              String
  storeId                 String
  isActive                Boolean                     @default(true)
  imageUrl                String?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  material                String?
  size                    String?
  stockGroupId            String?
  unitMultiplierToBase    Float                       @default(1)
  conversionNeedsReview   Boolean                     @default(false)
  hargaDinas              Decimal?                    @db.Decimal(12, 2)
  hargaAgen               Decimal?                    @db.Decimal(12, 2)
  batchItems              BatchOperationItem[]
  inventoryInboundLines    InventoryInboundReceiptLine[]
  inventoryLogs           InventoryLog[]
  inventoryLogCorrections InventoryLogCorrectionRequest[] @relation("inventory_log_corrected_product")
  inventoryProductionMaterials InventoryProductionMaterial[]
  internalStockOutRequests InternalStockOutRequest[]
  priceLogs               ProductPriceLog[]
  productSuppliers        ProductSupplier[]
  shoppingRequestItems    ShoppingRequestItem[]
  stockGroupActivities    ProductStockGroupActivity[]
  category                Category                    @relation(fields: [categoryId], references: [id])
  stockGroup              ProductStockGroup?          @relation(fields: [stockGroupId], references: [id])
  store                   Store                       @relation(fields: [storeId], references: [id])
  suratJalanItems         SuratJalanItem[]
  transactionProductItems TransactionItem[]           @relation("transaction_product")
  serviceMaterialItems    TransactionItem[]           @relation("transaction_raw_material")

  @@index([categoryId])
  @@index([storeId])
  @@index([stockGroupId])
  @@index([sku])
  @@index([barcode(ops: raw("gin_trgm_ops"))], map: "pos_products_barcode_trgm_idx", type: Gin)
  @@index([name(ops: raw("gin_trgm_ops"))], map: "pos_products_name_trgm_idx", type: Gin)
  @@index([sku(ops: raw("gin_trgm_ops"))], map: "pos_products_sku_trgm_idx", type: Gin)
  @@index([storeId, isActive, name], map: "pos_products_store_active_name_idx")
  @@index([storeId, categoryId, isActive, name], map: "pos_products_store_category_active_name_idx")
  @@map("pos_products")
}

model ProductStockGroup {
  id          String                      @id @default(cuid())
  storeId     String
  groupKey    String
  displayName String
  baseUnit    String                      @default("pcs")
  baseStock   Float                       @default(0)
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @default(now()) @updatedAt
  activities  ProductStockGroupActivity[]
  store       Store                       @relation(fields: [storeId], references: [id])
  products    Product[]

  @@unique([storeId, groupKey])
  @@index([storeId])
  @@index([storeId, groupKey])
  @@map("pos_product_stock_groups")
}

model ProductStockGroupActivity {
  id           String            @id @default(cuid())
  stockGroupId String
  productId    String?
  type         String
  note         String?
  createdBy    String?
  person       String?
  before       Json?
  after        Json?
  createdAt    DateTime          @default(now())
  product      Product?          @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockGroup   ProductStockGroup @relation(fields: [stockGroupId], references: [id], onDelete: Cascade)

  @@index([stockGroupId, createdAt])
  @@index([productId])
  @@index([stockGroupId, type, createdAt], map: "pos_product_stock_group_activities_stockGroupId_type_createdAt_")
  @@map("pos_product_stock_group_activities")
}

model PrintingService {
  id          String            @id @default(cuid())
  storeId     String
  name        String
  basePrice   Decimal           @db.Decimal(12, 2)
  unit        String            @default("pcs")
  description String?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  store       Store             @relation(fields: [storeId], references: [id])
  items       TransactionItem[]

  @@index([storeId, isActive])
  @@index([storeId, name])
  @@map("pos_printing_services")
}

model Transaction {
  id                       String                  @id @default(cuid())
  invoiceNumber            String?                 @unique
  storeId                  String
  cashierId                String?
  subtotal                 Decimal                 @db.Decimal(12, 2)
  discount                 Decimal                 @default(0) @db.Decimal(12, 2)
  tax                      Decimal                 @default(0) @db.Decimal(12, 2)
  total                    Decimal                 @db.Decimal(12, 2)
  paymentMethod            PaymentMethod           @default(CASH)
  amountPaid               Decimal                 @default(0) @db.Decimal(12, 2)
  change                   Decimal                 @default(0) @db.Decimal(12, 2)
  status                   TransactionStatus       @default(COMPLETED)
  note                     String?
  createdAt                DateTime                @default(now())
  customerName             String?
  salesName                String?
  salespersonId            String?
  estimatedDoneAt          DateTime?
  isJobOrder               Boolean                 @default(false)
  productionStatus         ProductionStatus?
  customerId               String?
  requestedById            String?
  offlineClientMutationId  String?                 @unique
  offlineOriginalPayload   Json?
  offlineSyncMetadata      Json?
  buktiTransaksiUrls       String[]                @default([])
  draftNumber              String?                 @unique
  stockManagedBySuratJalan Boolean                 @default(false)
  debtPaymentLogs          DebtPaymentLog[]
  expenses                 Expense[]
  inventoryLogs            InventoryLog[]
  productionActivityLogs   ProductionActivityLog[]
  suratJalan               SuratJalan[]
  items                    TransactionItem[]
  payments                 TransactionPayment[]
  cashier                  User?                   @relation("processed_transactions", fields: [cashierId], references: [id])
  customer                 Customer?               @relation(fields: [customerId], references: [id])
  requestedBy              User?                   @relation("requested_transactions", fields: [requestedById], references: [id])
  salesperson              Salesperson?            @relation(fields: [salespersonId], references: [id])
  store                    Store                   @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([cashierId])
  @@index([requestedById])
  @@index([customerId])
  @@index([salespersonId])
  @@index([createdAt])
  @@index([status])
  @@index([draftNumber])
  @@index([offlineClientMutationId])
  @@index([customerId, storeId, status, createdAt], map: "pos_transactions_customer_store_status_createdAt_idx")
  @@index([storeId, createdAt(sort: Desc)], map: "pos_transactions_store_createdAt_desc_idx")
  @@index([storeId, isJobOrder, productionStatus, createdAt(sort: Desc)], map: "pos_transactions_store_job_production_createdAt_desc_idx")
  @@index([storeId, paymentMethod, createdAt(sort: Desc)], map: "pos_transactions_store_payment_createdAt_desc_idx")
  @@index([storeId, status, createdAt(sort: Desc)], map: "pos_transactions_store_status_createdAt_desc_idx")
  @@map("pos_transactions")
}

model ProductionActivityLog {
  id            String                      @id @default(cuid())
  transactionId String
  storeId       String
  invoiceNumber String?
  customerName  String?
  fromStatus    ProductionStatus?
  toStatus      ProductionStatus
  actorId       String?
  actorName     String
  actorRole     Role
  createdAt     DateTime                    @default(now())
  eventType     ProductionActivityEventType @default(STATUS_CHANGE)
  note          String?
  actor         User?                       @relation("production_activity_actor", fields: [actorId], references: [id])
  store         Store                       @relation(fields: [storeId], references: [id])
  transaction   Transaction                 @relation(fields: [transactionId], references: [id])

  @@index([storeId, createdAt])
  @@index([transactionId, createdAt])
  @@index([actorId, createdAt])
  @@index([eventType, createdAt])
  @@index([fromStatus, toStatus, createdAt])
  @@map("pos_production_activity_logs")
}

/// This model contains an index with non-default null sort order and requires additional setup for migrations. Visit https://pris.ly/d/default-index-null-ordering for more info.
model Customer {
  id              String           @id @default(cuid())
  name            String
  phone           String?
  email           String?
  company         String?
  address         String?
  type            CustomerType     @default(UMUM)
  notes           String?
  totalSpent      Decimal          @default(0) @db.Decimal(12, 2)
  totalOrders     Int              @default(0)
  loyaltyPoint    Int              @default(0)
  lastVisitAt     DateTime?
  storeId         String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  totalDebt       Decimal          @default(0) @db.Decimal(12, 2)
  store           Store            @relation(fields: [storeId], references: [id])
  debtPaymentLogs DebtPaymentLog[]
  transactions    Transaction[]

  @@index([storeId])
  @@index([phone])
  @@index([type])
  @@index([company(ops: raw("gin_trgm_ops"))], map: "pos_customers_company_trgm_idx", type: Gin)
  @@index([email(ops: raw("gin_trgm_ops"))], map: "pos_customers_email_trgm_idx", type: Gin)
  @@index([name(ops: raw("gin_trgm_ops"))], map: "pos_customers_name_trgm_idx", type: Gin)
  @@index([phone(ops: raw("gin_trgm_ops"))], map: "pos_customers_phone_trgm_idx", type: Gin)
  @@index([storeId, lastVisitAt(sort: Desc)], map: "pos_customers_store_lastVisitAt_desc_idx")
  @@index([storeId, phone], map: "pos_customers_store_phone_idx")
  @@index([storeId, type, lastVisitAt(sort: Desc)], map: "pos_customers_store_type_lastVisitAt_desc_idx")
  @@map("pos_customers")
}

model Supplier {
  id               String            @id @default(cuid())
  code             String?           @unique
  name             String
  type             SupplierType
  phone            String?
  contactPerson    String?
  address          String?
  notes            String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  inboundReceipts  InventoryInboundReceipt[]
  inventoryLogs    InventoryLog[]
  productSuppliers ProductSupplier[]
  shoppingRequests ShoppingRequest[]

  @@index([isActive])
  @@index([type])
  @@index([name])
  @@map("pos_suppliers")
}

model ProductSupplier {
  productId  String
  supplierId String
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@id([productId, supplierId])
  @@index([supplierId])
  @@map("pos_product_suppliers")
}

model DebtPaymentLog {
  id            String        @id @default(cuid())
  transactionId String
  customerId    String
  storeId       String
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  note          String?
  createdAt     DateTime      @default(now())
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  store         Store         @relation(fields: [storeId], references: [id])
  transaction   Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt])
  @@index([customerId, createdAt])
  @@index([transactionId])
  @@map("pos_debt_payment_logs")
}

model TransactionPayment {
  id            String        @id @default(cuid())
  transactionId String
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod
  createdAt     DateTime      @default(now())

  transaction   Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@map("pos_transaction_payments")
}

model Salesperson {
  id           String        @id @default(cuid())
  name         String
  isActive     Boolean       @default(true)
  storeId      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  store        Store         @relation(fields: [storeId], references: [id])
  transactions Transaction[]

  @@index([storeId])
  @@index([storeId, isActive, name], map: "pos_salespersons_store_active_name_idx")
  @@map("pos_salespersons")
}

model TransactionItem {
  id                   String                       @id @default(cuid())
  transactionId        String
  productId            String?
  productName          String
  quantity             Int
  unitPrice            Decimal                      @db.Decimal(12, 2)
  discount             Decimal                      @default(0) @db.Decimal(12, 2)
  subtotal             Decimal                      @db.Decimal(12, 2)
  material             String?
  size                 String?
  unitCost             Decimal?                     @db.Decimal(12, 2)
  printingServiceId    String?
  rawMaterialProductId String?
  serviceNote          String?
  rawMaterialQuantity  Float?
  rawMaterialUnit      String?
  pricingRuleId        String?
  pricingCustomerType  CustomerType?
  pricingCategoryId    String?
  pricingCategoryName  String?
  pricingMode          CategoryCustomerPricingMode?
  pricingValue         Decimal?                     @db.Decimal(12, 2)
  originalUnitPrice    Decimal?                     @db.Decimal(12, 2)
  appliedUnitPrice     Decimal?                     @db.Decimal(12, 2)
  suratJalanItems      SuratJalanItem[]
  printingService      PrintingService?             @relation(fields: [printingServiceId], references: [id])
  product              Product?                     @relation("transaction_product", fields: [productId], references: [id], onDelete: Restrict)
  rawMaterialProduct   Product?                     @relation("transaction_raw_material", fields: [rawMaterialProductId], references: [id])
  transaction          Transaction                  @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([productId])
  @@index([printingServiceId])
  @@index([rawMaterialProductId])
  @@index([pricingRuleId])
  @@map("pos_transaction_items")
}

model InventoryLog {
  id              String             @id @default(cuid())
  productId       String
  type            InventoryType
  quantity        Float
  note            String?
  createdBy       String?
  createdAt       DateTime           @default(now())
  person          String?
  reason          InventoryReason?
  unitCost        Decimal?           @db.Decimal(12, 2)
  status          InventoryLogStatus @default(APPROVED)
  approvedBy      String?
  approverName    String?
  decidedAt       DateTime?
  rejectionReason String?
  supplierId      String?
  transactionId   String?
  suratJalanId    String?
  product         Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  verification    InventoryLogVerification?
  correctionRequests InventoryLogCorrectionRequest[] @relation("inventory_log_correction_source")
  correctionMovements InventoryLogCorrectionMovement[]
  supplier        Supplier?          @relation(fields: [supplierId], references: [id])
  suratJalan      SuratJalan?        @relation(fields: [suratJalanId], references: [id])
  transaction     Transaction?       @relation(fields: [transactionId], references: [id])

  @@index([productId])
  @@index([supplierId, createdAt])
  @@index([createdAt])
  @@index([reason, createdAt])
  @@index([status, createdAt])
  @@index([transactionId, createdAt])
  @@index([suratJalanId, createdAt])
  @@map("pos_inventory_logs")
}

model InventoryLogVerification {
  id             String                         @id @default(cuid())
  storeId        String
  inventoryLogId String                         @unique
  status         InventoryLogVerificationStatus @default(UNVERIFIED)
  note           String?
  verifiedBy     String?
  verifiedAt     DateTime?
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt
  inventoryLog   InventoryLog                   @relation(fields: [inventoryLogId], references: [id], onDelete: Cascade)
  store          Store                          @relation(fields: [storeId], references: [id])
  verifier       User?                          @relation("inventory_log_verifier", fields: [verifiedBy], references: [id])

  @@index([storeId, status, updatedAt])
  @@index([verifiedBy, verifiedAt])
  @@map("pos_inventory_log_verifications")
}

model InventoryLogCorrectionRequest {
  id                 String                       @id @default(cuid())
  storeId            String
  inventoryLogId     String
  correctedProductId String
  correctedQuantity  Float
  correctedReason    InventoryReason
  correctedNote      String?
  status             InventoryLogCorrectionStatus @default(PENDING)
  requestedBy        String
  decidedBy          String?
  decidedAt          DateTime?
  rejectionReason    String?
  version            Int                          @default(1)
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  store              Store                        @relation(fields: [storeId], references: [id])
  inventoryLog       InventoryLog                 @relation("inventory_log_correction_source", fields: [inventoryLogId], references: [id], onDelete: Cascade)
  correctedProduct   Product                      @relation("inventory_log_corrected_product", fields: [correctedProductId], references: [id])
  requester          User                         @relation("inventory_log_correction_requester", fields: [requestedBy], references: [id])
  decider            User?                        @relation("inventory_log_correction_decider", fields: [decidedBy], references: [id])
  movements          InventoryLogCorrectionMovement[]

  @@index([storeId, status, createdAt])
  @@index([inventoryLogId, status, createdAt])
  @@index([correctedProductId])
  @@index([requestedBy, createdAt])
  @@map("pos_inventory_log_correction_requests")
}

model InventoryLogCorrectionMovement {
  id                  String                             @id @default(cuid())
  correctionRequestId String
  inventoryLogId      String                             @unique
  kind                InventoryLogCorrectionMovementKind
  createdAt           DateTime                           @default(now())
  correctionRequest   InventoryLogCorrectionRequest      @relation(fields: [correctionRequestId], references: [id], onDelete: Cascade)
  inventoryLog        InventoryLog                       @relation(fields: [inventoryLogId], references: [id], onDelete: Cascade)

  @@index([correctionRequestId, kind])
  @@map("pos_inventory_log_correction_movements")
}

model InventoryTask {
  id                    String              @id @default(cuid())
  storeId               String
  type                  InventoryTaskType
  periodType            InventoryTaskPeriod
  periodKey             String
  status                InventoryTaskStatus @default(PENDING)
  proofUrl              String?
  resolvedProofImageUrl String?
  note                  String?
  submittedBy           String?
  submittedAt           DateTime?
  completionSnapshot    Json?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  store                 Store               @relation(fields: [storeId], references: [id])
  submitter             User?               @relation("inventory_task_submitter", fields: [submittedBy], references: [id])

  @@unique([storeId, type, periodKey])
  @@index([storeId, type, status])
  @@index([submittedBy, submittedAt])
  @@map("pos_inventory_tasks")
}

model InventoryDaySession {
  id                   String    @id @default(cuid())
  storeId              String
  periodKey            String
  status               String    @default("NOT_CHECKED_IN")
  morningCheckSnapshot Json?
  checkOutSnapshot     Json?
  checkInById          String?
  checkInByName        String?
  checkedInAt          DateTime?
  checkOutById         String?
  checkOutByName       String?
  checkedOutAt         DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  store                Store     @relation(fields: [storeId], references: [id])
  checkInBy            User?     @relation("inventory_day_session_checkin", fields: [checkInById], references: [id])
  checkOutBy           User?     @relation("inventory_day_session_checkout", fields: [checkOutById], references: [id])

  @@unique([storeId, periodKey])
  @@index([storeId, status, periodKey])
  @@index([checkInById, checkedInAt])
  @@index([checkOutById, checkedOutAt])
  @@map("pos_inventory_day_sessions")
}

model InventoryProductionMaterial {
  id          String   @id @default(cuid())
  storeId     String
  productId   String
  source      String   @default("PINNED")
  isPinned    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  store       Store    @relation(fields: [storeId], references: [id])
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, productId])
  @@index([storeId, isPinned])
  @@map("pos_inventory_production_materials")
}

model InventoryTaskChecklistItem {
  id            String                    @id @default(cuid())
  storeId       String
  periodType    InventoryTaskPeriod
  periodKey     String
  title         String
  dueTime       String?
  priority      InventoryTaskPriority     @default(NORMAL)
  isCompleted   Boolean                   @default(false)
  completedById String?
  completedAt   DateTime?
  createdById   String
  updatedById   String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  store         Store                     @relation(fields: [storeId], references: [id])
  creator       User                      @relation("inventory_task_checklist_creator", fields: [createdById], references: [id])
  updater       User?                     @relation("inventory_task_checklist_updater", fields: [updatedById], references: [id])
  completer     User?                     @relation("inventory_task_checklist_completer", fields: [completedById], references: [id])

  @@index([storeId, periodType, periodKey], map: "pos_inv_task_checklist_period_idx")
  @@index([storeId, periodType, periodKey, isCompleted], map: "pos_inv_task_checklist_period_done_idx")
  @@index([completedById, completedAt])
  @@map("pos_inventory_task_checklist_items")
}

model SuratJalan {
  id              String           @id @default(cuid())
  transactionId   String
  storeId         String
  number          String           @unique
  recipientName   String
