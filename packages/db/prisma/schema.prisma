// Prisma Schema for POS System - Toko Percetakan & ATK
// All tables use pos_ prefix to avoid conflicts

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  OWNER
  SALES
  CASHIER
  ADMIN
}

enum PaymentMethod {
  CASH
  DEBIT
  CREDIT
  QRIS
  TRANSFER
}

enum TransactionStatus {
  PENDING_APPROVAL
  COMPLETED
  DP
  VOIDED
  REFUNDED
}

enum InventoryType {
  IN
  OUT
  ADJUSTMENT
}

enum BatchOperationType {
  PRODUCT_IMPORT
  BULK_STOCK_ADJUSTMENT
  UNDO
}

enum BatchOperationStatus {
  COMMITTED
  UNDONE
  UNDO_BLOCKED
}

enum BatchOperationItemAction {
  CREATE
  UPDATE
  SKIP
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  UNDO
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum ProductionStatus {
  PENDING
  DESIGNING
  PRINTING
  FINISHING
  READY_PICKUP
  DELIVERED
}

enum CustomerType {
  REGULAR
  VIP
  CORPORATE
}

// ============================================================
// MODELS
// ============================================================

model User {
  id                    String        @id @default(cuid())
  username              String        @unique
  name                  String
  role                  Role          @default(CASHIER)
  password              String?       // password for quick POS login
  avatarUrl             String?
  isActive              Boolean       @default(true)
  storeId               String?
  store                 Store?        @relation(fields: [storeId], references: [id])
  transactions          Transaction[] @relation("processed_transactions")
  requestedTransactions Transaction[] @relation("requested_transactions")
  shifts                CashierShift[]
  batchOperations       BatchOperation[] @relation("created_batch_operations")
  undoneBatchOperations BatchOperation[] @relation("undone_batch_operations")
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@map("pos_users")
}

model Store {
  id           String        @id @default(cuid())
  name         String
  address      String?
  phone        String?
  logoUrl      String?
  users        User[]
  products     Product[]
  transactions Transaction[]
  shifts       CashierShift[]
  salespersons Salesperson[]
  customers    Customer[]
  batchOperations BatchOperation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("pos_stores")
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique // "Alat Tulis", "Kertas", "Tinta", "Jasa Cetak", "Amplop", "Map"
  icon     String?   // Emoji or icon name
  color    String?   // Hex color for category badge
  order    Int       @default(0)
  products Product[]

  @@map("pos_categories")
}

model Product {
  id            String            @id @default(cuid())
  name          String
  sku           String            @unique
  barcode       String?
  description   String?
  price         Decimal           @db.Decimal(12, 2)
  costPrice     Decimal?          @db.Decimal(12, 2)
  stock         Float             @default(0)
  minStock      Int               @default(5)    // Alert when stock below this
  unit          String            @default("pcs") // pcs, rim, box, lembar, gsm, meter, roll, pack, lusin, kodi, set
  size          String?           // e.g., "3x2m", "A4", "F4"
  material      String?           // e.g., "Flexi 280gr", "Art Paper 150gsm"
  categoryId    String
  category      Category          @relation(fields: [categoryId], references: [id])
  storeId       String
  store         Store             @relation(fields: [storeId], references: [id])
  isActive      Boolean           @default(true)
  imageUrl      String?
  items         TransactionItem[]
  inventoryLogs InventoryLog[]
  batchItems    BatchOperationItem[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([categoryId])
  @@index([storeId])
  @@index([sku])
  @@map("pos_products")
}

model Transaction {
  id               String            @id @default(cuid())
  invoiceNumber    String            @unique
  storeId          String
  store            Store             @relation(fields: [storeId], references: [id])
  cashierId        String?           // Nullable: filled when Cashier approves a SALES request
  cashier          User?             @relation("processed_transactions", fields: [cashierId], references: [id])
  requestedById    String?           // The SALES user who created the request
  requestedBy      User?             @relation("requested_transactions", fields: [requestedById], references: [id])
  customerId       String?
  customer         Customer?         @relation(fields: [customerId], references: [id])
  salespersonId    String?
  salesperson      Salesperson?      @relation(fields: [salespersonId], references: [id])
  items            TransactionItem[]
  subtotal         Decimal           @db.Decimal(12, 2)
  discount         Decimal           @default(0) @db.Decimal(12, 2)
  tax              Decimal           @default(0) @db.Decimal(12, 2)
  total            Decimal           @db.Decimal(12, 2)
  paymentMethod    PaymentMethod     @default(CASH)
  amountPaid       Decimal           @default(0) @db.Decimal(12, 2)
  change           Decimal           @default(0) @db.Decimal(12, 2)
  status           TransactionStatus @default(COMPLETED)
  customerName     String?           // kept for walk-in / backward compat
  salesName        String?
  note             String?
  isJobOrder       Boolean           @default(false)
  productionStatus ProductionStatus?
  estimatedDoneAt  DateTime?
  offlineClientMutationId String?     @unique
  offlineOriginalPayload  Json?
  offlineSyncMetadata     Json?
  createdAt        DateTime          @default(now())

  @@index([storeId])
  @@index([cashierId])
  @@index([requestedById])
  @@index([customerId])
  @@index([salespersonId])
  @@index([createdAt])
  @@index([status])
  @@index([offlineClientMutationId])
  @@map("pos_transactions")
}

model Customer {
  id           String        @id @default(cuid())
  name         String
  phone        String?       // Standardized E.164 format e.g. +6281234567890
  email        String?
  company      String?
  address      String?
  type         CustomerType  @default(REGULAR)
  notes        String?       // Free-text notes (allergies, preferences, etc.)

  // Analytics — updated atomically on every transaction
  totalSpent   Decimal       @default(0) @db.Decimal(12, 2)
  totalOrders  Int           @default(0)
  totalDebt    Decimal       @default(0) @db.Decimal(12, 2) // Outstanding piutang (remaining from DP)
  loyaltyPoint Int           @default(0)
  lastVisitAt  DateTime?

  storeId      String
  store        Store         @relation(fields: [storeId], references: [id])
  transactions Transaction[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([storeId])
  @@index([phone])
  @@index([type])
  @@map("pos_customers")
}

model Salesperson {
  id           String        @id @default(cuid())
  name         String
  isActive     Boolean       @default(true)
  storeId      String
  store        Store         @relation(fields: [storeId], references: [id])
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([storeId])
  @@map("pos_salespersons")
}

model TransactionItem {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  productName   String      // Snapshot of product name at time of sale
  size          String?     // Snapshot of size
  material      String?     // Snapshot of material
  quantity      Int
  unitPrice     Decimal     @db.Decimal(12, 2)
  unitCost      Decimal?    @db.Decimal(12, 2)
  discount      Decimal     @default(0) @db.Decimal(12, 2)
  subtotal      Decimal     @db.Decimal(12, 2)

  @@index([transactionId])
  @@map("pos_transaction_items")
}

model InventoryLog {
  id        String        @id @default(cuid())
  productId String
  product   Product       @relation(fields: [productId], references: [id])
  type      InventoryType
  quantity  Float
  note      String?
  createdBy String?       // userId who made the change
  person    String?       // name of the person who performed the action
  createdAt DateTime      @default(now())

  @@index([productId])
  @@index([createdAt])
  @@map("pos_inventory_logs")
}

model BatchOperation {
  id              String               @id @default(cuid())
  type            BatchOperationType
  status          BatchOperationStatus @default(COMMITTED)
  storeId         String
  store           Store                @relation(fields: [storeId], references: [id])
  createdBy       String
  creator         User                 @relation("created_batch_operations", fields: [createdBy], references: [id])
  summary         Json
  items           BatchOperationItem[]
  createdAt       DateTime             @default(now())
  undoneAt        DateTime?
  undoneBy        String?
  undoneByUser    User?                @relation("undone_batch_operations", fields: [undoneBy], references: [id])
  undoOfBatchId   String?
  undoOfBatch     BatchOperation?      @relation("batch_operation_undo", fields: [undoOfBatchId], references: [id])
  undoOperations  BatchOperation[]     @relation("batch_operation_undo")

  @@index([storeId])
  @@index([createdAt])
  @@map("pos_batch_operations")
}

model BatchOperationItem {
  id               String                   @id @default(cuid())
  batchOperationId String
  batchOperation   BatchOperation           @relation(fields: [batchOperationId], references: [id], onDelete: Cascade)
  productId        String?
  product          Product?                 @relation(fields: [productId], references: [id])
  sku              String
  action           BatchOperationItemAction
  beforeSnapshot   Json?
  afterSnapshot    Json?
  inventoryLogId   String?
  createdAt        DateTime                 @default(now())

  @@index([batchOperationId])
  @@index([productId])
  @@index([productId, createdAt])
  @@map("pos_batch_operation_items")
}

model CashierShift {
  id              String      @id @default(cuid())
  cashierId       String
  cashier         User        @relation(fields: [cashierId], references: [id])
  storeId         String
  store           Store       @relation(fields: [storeId], references: [id])
  openingBalance  Decimal     @db.Decimal(12, 2)
  closingBalance  Decimal?    @db.Decimal(12, 2)
  expectedBalance Decimal?    @db.Decimal(12, 2)
  discrepancy     Decimal?    @db.Decimal(12, 2)
  status          ShiftStatus @default(OPEN)
  note            String?
  openedAt        DateTime    @default(now())
  closedAt        DateTime?

  @@index([cashierId])
  @@index([storeId])
  @@index([status])
  @@map("pos_cashier_shifts")
}

model PushSubscription {
  id          String   @id @default(cuid())
  endpoint    String   @unique
  userId      String
  role        Role
  storeId     String?
  auth        String?
  p256dh      String?
  features    Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([storeId])
  @@index([role])
  @@map("pos_push_subscriptions")
}

// ============================================================
// LEGACY TABLES (To prevent Prisma from dropping them)
// ============================================================

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model chat_messages {
  id            BigInt        @id @default(autoincrement())
  session_id    String        @db.Uuid
  role          String
  content       String
  meta          Json?
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  chat_id       String?       @db.Uuid
  title         String?       @default("New Chat")
  chats         chats?        @relation(fields: [chat_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  chat_sessions chat_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([chat_id, created_at], map: "chat_messages_chat_created_idx")
  @@index([session_id, created_at], map: "chat_messages_session_created_idx")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model chat_messages_teladan {
  id         BigInt   @id @default(autoincrement())
  phone      String
  role       String
  content    String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  image_url  String?

  @@index([phone, created_at(sort: Desc)], map: "idx_chat_messages_phone")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model chat_sessions {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_key    String          @unique
  title          String?
  created_at     DateTime        @default(now()) @db.Timestamptz(6)
  last_active_at DateTime        @default(now()) @db.Timestamptz(6)
  chat_messages  chat_messages[]
  chats          chats[]
  documents      documents[]

  @@index([last_active_at(sort: Desc)], map: "chat_sessions_last_active_idx")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model chats {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id     String          @db.Uuid
  title          String?
  created_at     DateTime        @default(now()) @db.Timestamptz(6)
  last_active_at DateTime        @default(now()) @db.Timestamptz(6)
  chat_messages  chat_messages[]
  chat_sessions  chat_sessions   @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([session_id, last_active_at(sort: Desc)], map: "chats_session_last_active_idx")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model documents {
  id            BigInt                 @id @default(autoincrement())
  content       String
  embedding     Unsupported("vector")?
  metadata      Json?                  @default("{}")
  created_at    DateTime?              @default(now()) @db.Timestamptz(6)
  session_id    String?                @db.Uuid
  chat_sessions chat_sessions?         @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([embedding])
  @@index([session_id], map: "documents_session_idx")
}

model papers_vectordb {
  id         BigInt                 @id @default(autoincrement())
  content    String
  embedding  Unsupported("vector")?
  metadata   Json?                  @default("{}")
  created_at DateTime?              @default(now()) @db.Timestamptz(6)

  @@index([embedding])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model products_teladan {
  code       String    @id @db.VarChar(50)
  name       String    @db.VarChar(255)
  unit       String?   @db.VarChar(50)
  price      Decimal   @db.Decimal(15, 2)
  category   String?   @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  @@index([code], map: "idx_products_code")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model receipts_teladan {
  id               BigInt    @id @default(autoincrement())
  transaction_id   String    @db.VarChar(50)
  transaction_date DateTime? @default(now()) @db.Timestamptz(6)
  customer_name    String?   @db.VarChar(100)
  item_name        String    @db.VarChar(255)
  size             String?   @db.VarChar(50)
  material         String?   @db.VarChar(50)
  quantity         String?   @db.VarChar(50)
  price_per_item   Decimal?  @db.Decimal(15, 2)
  total_price      Decimal?  @db.Decimal(15, 2)
  payment_method   String?   @db.VarChar(50)
  notes            String?
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  down_payment     Decimal?  @db.Decimal

  @@index([transaction_date(sort: Desc)], map: "idx_receipts_date")
  @@index([transaction_id], map: "idx_receipts_transaction_id")
}

// ============================================================
// STORE SETTINGS (singleton — id is always "store-main")
// ============================================================

model StoreSettings {
  id        String   @id @default("store-main")
  name      String   @default("")
  address   String   @default("")
  phone     String   @default("")
  logoUrl   String?
  updatedAt DateTime @updatedAt
}

model RolePermission {
  id        String   @id @default(cuid())
  role      Role
  scope     String
  target    String
  action    String
  allowed   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, scope, target, action])
  @@index([role])
  @@map("pos_role_permissions")
}

